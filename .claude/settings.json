{
  "permissions": {
    "deny": [
      "Read(./terraform/.env)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(./.git-crypt/**)",
      "Edit(./terraform/.env)",
      "Edit(~/.aws/credentials)",
      "Edit(~/.aws/config)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pentest-bash-gotchas.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-credential-reads.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-destructive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pentest-shellcheck.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/audit-bash.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "terraform-skill@antonbabenko": true
  },
  "extraKnownMarketplaces": {
    "antonbabenko": {
      "source": {
        "source": "github",
        "repo": "antonbabenko/terraform-skill"
      }
    }
  }
}
