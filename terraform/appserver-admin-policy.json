{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManageDeployerPolicies",
      "Effect": "Allow",
      "Action": [
        "iam:CreatePolicy",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListPolicyVersions",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:DeletePolicy",
        "iam:TagPolicy",
        "iam:UntagPolicy"
      ],
      "Resource": [
        "arn:aws:iam::*:policy/Appserver*"
      ]
    },
    {
      "Sid": "AttachDetachAppserverPolicies",
      "Effect": "Allow",
      "Action": [
        "iam:AttachUserPolicy",
        "iam:DetachUserPolicy"
      ],
      "Resource": "arn:aws:iam::*:user/*",
      "Condition": {
        "ArnLike": {
          "iam:PolicyARN": "arn:aws:iam::*:policy/Appserver*"
        }
      }
    },
    {
      "Sid": "ListUserPolicies",
      "Effect": "Allow",
      "Action": "iam:ListAttachedUserPolicies",
      "Resource": "arn:aws:iam::*:user/*"
    },
    {
      "Sid": "ManageDeployerUser",
      "Effect": "Allow",
      "Action": [
        "iam:CreateUser",
        "iam:GetUser",
        "iam:DeleteUser",
        "iam:ListAccessKeys",
        "iam:CreateAccessKey",
        "iam:UpdateAccessKey",
        "iam:DeleteAccessKey",
        "iam:AttachUserPolicy",
        "iam:DetachUserPolicy",
        "iam:ListAttachedUserPolicies"
      ],
      "Resource": "arn:aws:iam::*:user/appserver-deployer"
    },
    {
      "Sid": "ManageDeployerMFA",
      "Effect": "Allow",
      "Action": [
        "iam:ListMFADevices",
        "iam:EnableMFADevice",
        "iam:DeactivateMFADevice",
        "iam:ResyncMFADevice"
      ],
      "Resource": [
        "arn:aws:iam::*:user/appserver-deployer",
        "arn:aws:iam::*:mfa/appserver-deployer"
      ]
    },
    {
      "Sid": "ManageVirtualMFA",
      "Effect": "Allow",
      "Action": [
        "iam:CreateVirtualMFADevice",
        "iam:DeleteVirtualMFADevice",
        "iam:ListVirtualMFADevices"
      ],
      "Resource": [
        "arn:aws:iam::*:mfa/appserver-deployer",
        "arn:aws:iam::*:mfa/*"
      ]
    },
    {
      "Sid": "StateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:PutBucketVersioning",
        "s3:PutEncryptionConfiguration",
        "s3:PutBucketPublicAccessBlock",
        "s3:PutBucketPolicy",
        "s3:PutLifecycleConfiguration",
        "s3:ListBucket",
        "s3:ListBucketVersions",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:GetObjectVersion",
        "s3:DeleteObjectVersion"
      ],
      "Resource": [
        "arn:aws:s3:::appserver-tfstate-*",
        "arn:aws:s3:::appserver-tfstate-*/*"
      ]
    },
    {
      "Sid": "CostExplorer",
      "Effect": "Allow",
      "Action": [
        "ce:GetCostAndUsage"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CallerIdentity",
      "Effect": "Allow",
      "Action": "sts:GetCallerIdentity",
      "Resource": "*"
    }
  ]
}
