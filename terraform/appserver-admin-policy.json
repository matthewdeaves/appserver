{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManageDeployerPolicies",
      "Effect": "Allow",
      "Action": [
        "iam:CreatePolicy",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListPolicyVersions",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:ListAttachedUserPolicies",
        "iam:AttachUserPolicy"
      ],
      "Resource": [
        "arn:aws:iam::*:policy/Appserver*"
      ]
    },
    {
      "Sid": "ManageDeployerUser",
      "Effect": "Allow",
      "Action": [
        "iam:CreateUser",
        "iam:GetUser",
        "iam:ListAccessKeys",
        "iam:CreateAccessKey"
      ],
      "Resource": "arn:aws:iam::*:user/appserver-deployer"
    },
    {
      "Sid": "StateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:PutBucketVersioning",
        "s3:PutBucketEncryption",
        "s3:PutBucketPublicAccessBlock",
        "s3:PutBucketPolicy",
        "s3:HeadBucket"
      ],
      "Resource": "arn:aws:s3:::appserver-tfstate-*"
    },
    {
      "Sid": "CostExplorer",
      "Effect": "Allow",
      "Action": [
        "ce:GetCostAndUsage"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CallerIdentity",
      "Effect": "Allow",
      "Action": "sts:GetCallerIdentity",
      "Resource": "*"
    }
  ]
}
