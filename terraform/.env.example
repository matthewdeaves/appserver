export CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# MFA device ARN for the appserver-deployer IAM user. Set after the operator
# enrols a TOTP device on that user (Phase 2 of the IAM scoping rollout).
# Format: arn:aws:iam::<account-id>:mfa/appserver-deployer
# Used by `./scripts/appserver.sh auth` to pass --serial-number to sts:AssumeRole.
# export MFA_SERIAL_NUMBER="arn:aws:iam::123456789012:mfa/appserver-deployer"

# 004 — MFA serial for the shared admin user (rockport-admin, used by both
# projects). Required by `appserver.sh init`. The AppserverAdmin policy
# explicit-denies actions outside a tiny safe-list when
# aws:MultiFactorAuthPresent is false, so a leaked admin access key is
# useless without the second factor. Same MFA device the user enrolled on
# rockport-admin in spec 018.
# export APPSERVER_ADMIN_MFA_SERIAL="arn:aws:iam::123456789012:mfa/adminuser"
